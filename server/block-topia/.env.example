PORT=2567

# Comma-separated list of allowed browser origins for CORS.
# Production must include both the CNAME and the raw GitHub Pages origin.
CORS_ORIGIN=https://cryptomoonboys.com,https://crypto-moonboys.github.io

NODE_ENV=development

# Colyseus monitor credentials (protect /colyseus dashboard)
# In production: MONITOR_PASSWORD MUST be set or /colyseus is disabled.
MONITOR_USERNAME=admin
MONITOR_PASSWORD=

# Block Topia phase timings (milliseconds)
# In production these default to 10-minute free-roam / recovery.
# Override here only to shorten cycles for development/testing.
# BLOCKTOPIA_FREE_ROAM_MS=60000
# BLOCKTOPIA_WARNING_MS=10000
# BLOCKTOPIA_EVENT_MS=90000
# BLOCKTOPIA_RECOVERY_MS=30000
# BLOCKTOPIA_MISSION_COMPLETE_MS=8000
